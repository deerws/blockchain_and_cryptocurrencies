# Environment
.env
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files (too big or sensitive — regenerate via pipeline)
data/raw/*.parquet
data/raw/*.json
data/raw/wallets/*.parquet
data/processed/*.parquet
data/labeled/*.parquet
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/labeled/.gitkeep

# Indexer log (runtime artifact)
data/raw/indexer.log

# Models (large binary artifacts — not committed)
models/*.pkl
models/*.joblib
models/*.h5
!models/.gitkeep

# Reports (generated plots — not committed, user regenerates locally)
reports/figures/*.png
reports/figures/*.pdf
!reports/figures/.gitkeep

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Smart contracts
node_modules/
artifacts/
cache/
typechain-types/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env

# Logs
*.log
logs/
.env.local
