# ChainScore — Environment Variables
# Copy this file to .env and fill in your actual keys

# ── Ethereum RPC (Alchemy) ──────────────────────────────────────────
# Get a free API key at https://www.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_key_here
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ── Etherscan API ──────────────────────────────────────────────────
# Get a free API key at https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_key_here

# ── Database (local PostgreSQL for caching) ────────────────────────
DATABASE_URL=postgresql://chainscore:chainscore@localhost:5432/chainscore

# ── Model artifacts ────────────────────────────────────────────────
MODEL_PATH=./models/lightgbm_v1.pkl
FEATURE_VERSION=v1

# ── API config (Phase 3) ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY_SECRET=change_me_in_production

# ── Smart contract (Phase 3) ───────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}
DEPLOYER_PRIVATE_KEY=your_test_wallet_private_key_NEVER_COMMIT
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
